generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth Models ─────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  profile       Profile?
  sessions      Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Profile & RBAC ──────────────────────────────────────────────────────────

model Profile {
  id          String  @id @default(uuid())
  userId      String  @unique
  email       String  @unique
  fullName    String?
  nickName    String?
  phoneNumber String?
  avatarUrl   String?

  // Personal data
  placeOfBirth     String?
  dateOfBirth      DateTime?
  ktpAddress       String?
  currentAddress   String?
  motherName       String?
  maritalStatus    String?
  numberOfChildren Int?
  lastEducation    String?

  // Emergency contact
  emergencyContactName  String?
  emergencyContactRel   String?
  emergencyContactPhone String?

  // Access control
  roleId    String?
  dataScope DataScope     @default(own)
  status    ProfileStatus @default(active)

  // Metadata
  invitedBy          String?
  invitedAt          DateTime?
  isEmailVerified    Boolean   @default(false)
  mustChangePassword Boolean   @default(false)
  lastLoginAt        DateTime?
  timezone           String    @default("Asia/Jakarta")
  language           String    @default("id")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  activityLogs            ActivityLog[]
  role                    Role?                    @relation(fields: [roleId], references: [id])
  user                    User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userVenueAccess         UserVenueAccess[]
  dataGroupMemberships    UserGroupMember[]
  ledGroups               UserGroup[]              @relation("GroupLeader")
  bookingsAsSales         Booking[]                @relation("BookingSales")
  bookingsAsManager       Booking[]                @relation("BookingManager")
  uploadedDocuments       BookingDocument[]
  createdRefunds          BookingRefund[]
  notifications           Notification[]

  @@index([roleId])
  @@index([dataScope])
  @@map("profiles")
}

model Role {
  id              String           @id @default(uuid())
  name            String           @unique
  description     String?
  sortOrder       Int              @default(0)
  createdAt       DateTime         @default(now())
  profiles        Profile[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid())
  module          String
  action          String
  description     String?
  moduleSortOrder Int              @default(0)
  createdAt       DateTime         @default(now())
  rolePermissions RolePermission[]

  @@unique([module, action])
  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

// ─── Auth Tokens ─────────────────────────────────────────────────────────────

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  profile   Profile   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String    @id @default(uuid())
  profileId String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  profile   Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("email_verification_tokens")
}

// ─── Data Groups (untuk scope = 'group') ─────────────────────────────────────

model UserGroup {
  id          String            @id @default(uuid())
  name        String
  description String?
  leaderId    String?
  sortOrder   Int               @default(0)
  createdBy   String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  leader      Profile?          @relation("GroupLeader", fields: [leaderId], references: [id], onDelete: SetNull)
  members     UserGroupMember[]

  @@map("user_groups")
}

model UserGroupMember {
  groupId   String
  userId    String
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  group     UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  profile   Profile   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
  @@index([userId])
  @@map("user_group_members")
}

// ─── Venue (dipakai untuk user invitation — assign venue ke user) ─────────────

model Brand {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  createdAt DateTime @default(now())
  venues    Venue[]

  @@map("brands")
}

model Venue {
  id              String            @id @default(uuid())
  name            String
  description     String?
  address         String?
  capacity        Int?
  imageUrl        String?
  code            String            @default("KODE")
  brandId         String?
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  brand           Brand?            @relation(fields: [brandId], references: [id])
  userVenueAccess UserVenueAccess[]
  packages        Package[]
  paymentMethods  PaymentMethod[]
  bookings        Booking[]

  @@map("venues")
}

model UserVenueAccess {
  id        String           @id @default(uuid())
  userId    String
  venueId   String
  scope     VenueAccessScope @default(individual)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  profile   Profile          @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue     Venue            @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([userId, venueId])
  @@index([userId])
  @@map("user_venue_access")
}

// ─── Audit Logging ───────────────────────────────────────────────────────────

model ActivityLog {
  id          String   @id @default(uuid())
  userId      String?
  action      String
  result      String   @default("success")
  entityType  String
  entityId    String
  changes     Json     @default("{}")
  description String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  profile     Profile? @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([userId])
  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([entityType, entityId, createdAt])
  @@map("activity_logs")
}

// ─── Vendors ─────────────────────────────────────────────────────────────────

model VendorCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  vendors     Vendor[]

  @@map("vendor_categories")
}

model Vendor {
  id             String          @id @default(uuid())
  name           String
  categoryId     String
  description    String?
  phone          String?
  address        String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  category       VendorCategory  @relation(fields: [categoryId], references: [id])
  paymentMethods PaymentMethod[]

  @@index([categoryId])
  @@map("vendors")
}

model PaymentMethod {
  id                String          @id @default(uuid())
  vendorId          String?
  venueId           String?
  bankName          String
  bankAccountNumber String
  bankRecipient     String
  createdAt         DateTime        @default(now())
  vendor            Vendor?         @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  venue             Venue?          @relation(fields: [venueId], references: [id], onDelete: Cascade)
  bookings          Booking[]
  bookingRefunds    BookingRefund[]

  @@index([vendorId])
  @@index([venueId])
  @@map("payment_methods")
}

// ─── Packages ────────────────────────────────────────────────────────────────

model Package {
  id          String           @id @default(uuid())
  packageName String
  available   Boolean          @default(true)
  venueId     String?
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  venue       Venue?           @relation(fields: [venueId], references: [id])
  variants    PackageVariant[]
  bookings    Booking[]

  @@index([venueId])
  @@map("packages")
}

model PackageVariant {
  id            String                @id @default(uuid())
  packageId     String
  variantName   String
  pax           Int
  price         Int
  available     Boolean               @default(true)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  package       Package               @relation(fields: [packageId], references: [id], onDelete: Cascade)
  vendorItems   PackageVendorItem[]
  internalItems PackageInternalItem[]

  @@index([packageId])
  @@map("package_variants")
}

model PackageVendorItem {
  id               String         @id @default(uuid())
  packageVariantId String
  categoryName     String
  itemText         String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  packageVariant   PackageVariant @relation(fields: [packageVariantId], references: [id], onDelete: Cascade)

  @@index([packageVariantId])
  @@map("package_vendor_items")
}

model PackageInternalItem {
  id               String         @id @default(uuid())
  packageVariantId String
  itemName         String
  itemDescription  String         @default("")
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  packageVariant   PackageVariant @relation(fields: [packageVariantId], references: [id], onDelete: Cascade)

  @@index([packageVariantId])
  @@map("package_internal_items")
}

// ─── Customers ───────────────────────────────────────────────────────────────

model Customer {
  id           String    @id @default(uuid())
  name         String
  mobileNumber String
  email        String
  nikNumber    String?
  ktpAddress   String?
  type         String
  club         String?
  memberStatus String    @default("Non-Member")
  notes        String?
  updatedBy    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  bookings     Booking[]

  @@index([name])
  @@index([mobileNumber])
  @@map("customers")
}

// ─── Customer Member Status ───────────────────────────────────────────────────

model CustomerMemberStatus {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  @@map("customer_member_statuses")
}

// ─── Source of Information ────────────────────────────────────────────────────

model SourceOfInformation {
  id        String    @id @default(uuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  bookings  Booking[]

  @@map("source_of_informations")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum ProfileStatus {
  active
  inactive
  suspended
}

enum DataScope {
  own
  group
  all
}

enum VenueAccessScope {
  general
  individual
}

enum EventSession {
  pagi
  malam
  fullday
}

// ─── Bookings ────────────────────────────────────────────────────────────────

model Booking {
  id                    String          @id @default(uuid())
  bookingDate           DateTime
  bookingStatus         BookingStatus   @default(Pending)
  paymentStatus         String          @default("")
  weddingSession        WeddingSession?
  weddingType           WeddingType?
  poNumber              String?
  rejectionNotes        String?
  lostReason            String?
  signingLocation       String?
  signatures            Json?
  vendorComments        Json?           @default("{}")
  salesId               String
  managerId             String?
  customerId            String
  venueId               String
  packageId             String
  packageVariantId      String?
  paymentMethodId       String?
  sourceOfInformationId String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  sales               Profile              @relation("BookingSales", fields: [salesId], references: [id])
  manager             Profile?             @relation("BookingManager", fields: [managerId], references: [id])
  customer            Customer             @relation(fields: [customerId], references: [id])
  venue               Venue                @relation(fields: [venueId], references: [id])
  package             Package              @relation(fields: [packageId], references: [id])
  paymentMethod       PaymentMethod?       @relation(fields: [paymentMethodId], references: [id])
  sourceOfInformation SourceOfInformation? @relation(fields: [sourceOfInformationId], references: [id])

  // Snapshot relations (1:1)
  snapCustomer       SnapCustomer?
  snapVenue          SnapVenue?
  snapPackage        SnapPackage?
  snapPackageVariant SnapPackageVariant?

  // Snapshot relations (1:many)
  snapPackageInternalItems SnapPackageInternalItem[]
  snapPackageVendorItems   SnapPackageVendorItem[]
  snapBonuses              SnapBonus[]
  snapVendorItems          SnapVendorItem[]

  // Live relations
  termOfPayments   TermOfPayment[]
  bookingDocuments BookingDocument[]
  bookingRefunds   BookingRefund[]
  clientAgreement  ClientAgreement?

  @@index([salesId])
  @@index([managerId])
  @@index([customerId])
  @@index([venueId])
  @@index([packageId])
  @@index([bookingStatus])
  @@index([bookingDate])
  @@map("bookings")
}

// ─── Snapshot Tables ─────────────────────────────────────────────────────────

model SnapCustomer {
  id           String   @id @default(uuid())
  bookingId    String   @unique
  customerId   String
  name         String
  email        String
  mobileNumber String
  nikNumber    String?
  ktpAddress   String?
  createdAt    DateTime @default(now())
  booking      Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("snap_customers")
}

model SnapVenue {
  id              String   @id @default(uuid())
  bookingId       String   @unique
  venueId         String
  venueName       String
  address         String?
  description     String?
  extraHoursPrice BigInt?
  brandName       String?
  brandCode       String?
  createdAt       DateTime @default(now())
  booking         Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("snap_venues")
}

model SnapPackage {
  id          String   @id @default(uuid())
  bookingId   String   @unique
  packageId   String
  packageName String
  notes       String?
  createdAt   DateTime @default(now())
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("snap_packages")
}

model SnapPackageVariant {
  id          String   @id @default(uuid())
  bookingId   String   @unique
  variantId   String
  variantName String
  pax         Int
  price       BigInt
  createdAt   DateTime @default(now())
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("snap_package_variants")
}

model SnapPackageInternalItem {
  id              String   @id @default(uuid())
  bookingId       String
  itemName        String
  itemDescription String   @default("")
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  booking         Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("snap_package_internal_items")
}

model SnapPackageVendorItem {
  id           String   @id @default(uuid())
  bookingId    String
  categoryName String
  itemText     String
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  booking      Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("snap_package_vendor_items")
}

model SnapBonus {
  id               String   @id @default(uuid())
  bookingId        String
  vendorId         String
  vendorCategoryId String
  vendorName       String
  description      String?
  qty              Int      @default(1)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  booking          Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("snap_bonuses")
}

model SnapVendorItem {
  id                 String   @id @default(uuid())
  bookingId          String
  vendorCategoryId   String
  vendorCategoryName String
  vendorId           String
  vendorName         String
  itemName           String
  itemPrice          BigInt   @default(0)
  qty                Int      @default(1)
  unit               String?
  totalPrice         BigInt   @default(0)
  isAddons           Boolean  @default(false)
  paketData          Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  booking            Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("snap_vendor_items")
}

// ─── Booking Live Tables ─────────────────────────────────────────────────────

model TermOfPayment {
  id              String              @id @default(uuid())
  bookingId       String
  name            String
  amount          BigInt
  dueDate         DateTime
  paymentStatus   TermOfPaymentStatus @default(unpaid)
  paymentEvidence String?
  invoiceNumber   String?
  notes           String?
  sortOrder       Int                 @default(0)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  booking         Booking             @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("term_of_payments")
}

model BookingDocument {
  id          String   @id @default(uuid())
  bookingId   String
  name        String
  description String?
  filePath    String
  fileName    String
  fileSize    Int      @default(0)
  fileType    String?
  uploadedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  uploader    Profile? @relation(fields: [uploadedBy], references: [id])

  @@index([bookingId])
  @@map("booking_documents")
}

model BookingRefund {
  id               String              @id @default(uuid())
  bookingId        String
  vendorId         String
  vendorCategoryId String
  amount           BigInt              @default(0)
  paymentMethodId  String
  status           BookingRefundStatus @default(pending)
  notes            String?
  refundDate       DateTime?
  createdBy        String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  booking          Booking             @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  paymentMethod    PaymentMethod       @relation(fields: [paymentMethodId], references: [id])
  creator          Profile?            @relation(fields: [createdBy], references: [id])

  @@index([bookingId])
  @@index([status])
  @@map("booking_refunds")
}

// ─── Booking Enums ───────────────────────────────────────────────────────────

enum BookingStatus {
  Pending
  Uploaded
  Confirmed
  Rejected
  Canceled
  Lost
}

enum WeddingSession {
  morning
  afternoon
  evening
  fullday
}

enum WeddingType {
  wedding
  engagement
  akad
  resepsi
  other
}

enum TermOfPaymentStatus {
  unpaid
  paid
  partial
}

enum BookingRefundStatus {
  pending
  completed
  cancelled
}

enum AgreementStatus {
  Pending
  Sent
  Viewed
  Signed
}

// ─── Client Agreement ─────────────────────────────────────────────────────────

model ClientAgreement {
  id         String          @id @default(uuid())
  bookingId  String          @unique
  token      String          @unique
  accessCode String
  status     AgreementStatus @default(Pending)
  sentAt     DateTime?
  viewedAt   DateTime?
  signedAt   DateTime?
  expiresAt  DateTime
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("client_agreements")
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id         String   @id @default(uuid())
  userId     String
  title      String
  message    String
  type       String
  entityType String?
  entityId   String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  profile    Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([userId, createdAt])
  @@map("notifications")
}
