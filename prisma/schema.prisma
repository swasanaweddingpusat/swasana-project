generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  profile       Profile?
  sessions      Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Profile {
  id                                                                   String                     @id @default(uuid())
  userId                                                               String                     @unique
  email                                                                String                     @unique
  fullName                                                             String?
  phoneNumber                                                          String?
  avatarUrl                                                            String?
  roleId                                                               String?
  status                                                               ProfileStatus              @default(active)
  invitedBy                                                            String?
  invitedAt                                                            DateTime?
  isEmailVerified                                                      Boolean                    @default(false)
  mustChangePassword                                                   Boolean                    @default(false)
  lastLoginAt                                                          DateTime?
  language                                                             String                     @default("id")
  createdAt                                                            DateTime                   @default(now())
  updatedAt                                                            DateTime                   @updatedAt
  currentAddress                                                       String?
  dataScope                                                            DataScope                  @default(own)
  dateOfBirth                                                          DateTime?
  emergencyContactName                                                 String?
  emergencyContactPhone                                                String?
  emergencyContactRel                                                  String?
  ktpAddress                                                           String?
  lastEducation                                                        String?
  maritalStatus                                                        String?
  motherName                                                           String?
  nickName                                                             String?
  numberOfChildren                                                     Int?
  placeOfBirth                                                         String?
  bankAccountHolder                                                    String?
  bankAccountNumber                                                    String?
  bankName                                                             String?
  city                                                                 String?
  gender                                                               Gender?
  kkNumber                                                             String?
  nik                                                                  String?
  employeeNumber                                                       Int                        @unique @default(autoincrement())
  activityLogs                                                         ActivityLog[]
  approval_flow_steps                                                  approval_flow_steps[]
  approval_record_steps_approval_record_steps_approverUserIdToprofiles approval_record_steps[]    @relation("approval_record_steps_approverUserIdToprofiles")
  approval_record_steps_approval_record_steps_decidedByIdToprofiles    approval_record_steps[]    @relation("approval_record_steps_decidedByIdToprofiles")
  approval_records                                                     approval_records[]
  bookingCommentReads                                                  BookingCommentRead[]
  bookingComments                                                      BookingComment[]
  uploadedDocuments                                                    BookingDocument[]
  createdSettlements                                                   BookingPaymentSettlement[]
  bookingsAsManager                                                    Booking[]                  @relation("BookingManager")
  bookingsAsSales                                                      Booking[]                  @relation("BookingSales")
  emailVerificationTokens                                              EmailVerificationToken[]
  notifications                                                        Notification[]
  passwordResetTokens                                                  PasswordResetToken[]
  role                                                                 Role?                      @relation(fields: [roleId], references: [id])
  user                                                                 User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  dataGroupMemberships                                                 UserGroupMember[]
  ledGroups                                                            UserGroup[]                @relation("GroupLeader")
  userVenueAccess                                                      UserVenueAccess[]

  @@index([roleId])
  @@index([dataScope])
  @@map("profiles")
}

model Role {
  id                    String                  @id @default(uuid())
  name                  String                  @unique
  description           String?
  sortOrder             Int                     @default(0)
  createdAt             DateTime                @default(now())
  approval_flow_steps   approval_flow_steps[]
  approval_record_steps approval_record_steps[]
  profiles              Profile[]
  rolePermissions       RolePermission[]

  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid())
  module          String
  action          String
  description     String?
  createdAt       DateTime         @default(now())
  moduleSortOrder Int              @default(0)
  rolePermissions RolePermission[]

  @@unique([module, action])
  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  profile   Profile   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String    @id @default(uuid())
  profileId String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  profile   Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("email_verification_tokens")
}

model UserGroup {
  id          String            @id @default(uuid())
  name        String
  description String?
  leaderId    String?
  sortOrder   Int               @default(0)
  createdBy   String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  members     UserGroupMember[]
  leader      Profile?          @relation("GroupLeader", fields: [leaderId], references: [id])

  @@map("user_groups")
}

model UserGroupMember {
  groupId   String
  userId    String
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  group     UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  profile   Profile   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
  @@index([userId])
  @@map("user_group_members")
}

model Brand {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  createdAt DateTime @default(now())
  venues    Venue[]

  @@map("brands")
}

model Venue {
  id              String            @id @default(uuid())
  name            String
  address         String?
  capacity        Int?
  imageUrl        String?
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  code            String            @default("KODE")
  description     String?
  brandId         String?
  bookings        Booking[]
  packages        Package[]
  paymentMethods  PaymentMethod[]
  userVenueAccess UserVenueAccess[]
  brand           Brand?            @relation(fields: [brandId], references: [id])

  @@map("venues")
}

model UserVenueAccess {
  id        String           @id @default(uuid())
  userId    String
  venueId   String
  scope     VenueAccessScope @default(individual)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  profile   Profile          @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue     Venue            @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([userId, venueId])
  @@index([userId])
  @@map("user_venue_access")
}

model ActivityLog {
  id          String   @id @default(uuid())
  userId      String?
  action      String
  result      String   @default("success")
  entityType  String
  entityId    String
  changes     Json     @default("{}")
  description String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  profile     Profile? @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([userId])
  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([entityType, entityId, createdAt])
  @@map("activity_logs")
}

model VendorCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  vendors     Vendor[]

  @@map("vendor_categories")
}

model Vendor {
  id             String          @id @default(uuid())
  name           String
  categoryId     String
  description    String?
  phone          String?
  address        String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  paymentMethods PaymentMethod[]
  category       VendorCategory  @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
  @@map("vendors")
}

model PaymentMethod {
  id                String                     @id @default(uuid())
  vendorId          String?
  venueId           String?
  bankName          String
  bankAccountNumber String
  bankRecipient     String
  createdAt         DateTime                   @default(now())
  settlements       BookingPaymentSettlement[]
  bookings          Booking[]
  vendor            Vendor?                    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  venue             Venue?                     @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([venueId])
  @@map("payment_methods")
}

model Package {
  id             String           @id @default(uuid())
  packageName    String
  available      Boolean          @default(true)
  venueId        String?
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  approvalStatus String           @default("draft")
  bookings       Booking[]
  variants       PackageVariant[]
  venue          Venue?           @relation(fields: [venueId], references: [id])

  @@index([venueId])
  @@map("packages")
}

model PackageVariant {
  id                              String                            @id @default(uuid())
  packageId                       String
  variantName                     String
  pax                             Int
  available                       Boolean                           @default(true)
  createdAt                       DateTime                          @default(now())
  updatedAt                       DateTime                          @updatedAt
  margin                          Float                             @default(0)
  internalItems                   PackageInternalItem[]
  package_variant_category_prices package_variant_category_prices[]
  package                         Package                           @relation(fields: [packageId], references: [id], onDelete: Cascade)
  vendorItems                     PackageVendorItem[]

  @@index([packageId])
  @@map("package_variants")
}

model PackageVendorItem {
  id               String         @id @default(uuid())
  packageVariantId String
  categoryName     String
  itemText         String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  packageVariant   PackageVariant @relation(fields: [packageVariantId], references: [id], onDelete: Cascade)

  @@index([packageVariantId])
  @@map("package_vendor_items")
}

model PackageInternalItem {
  id               String         @id @default(uuid())
  packageVariantId String
  itemName         String
  itemDescription  String         @default("")
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  packageVariant   PackageVariant @relation(fields: [packageVariantId], references: [id], onDelete: Cascade)

  @@index([packageVariantId])
  @@map("package_internal_items")
}

model Customer {
  id           String    @id @default(uuid())
  name         String
  mobileNumber String
  email        String
  nikNumber    String?
  ktpAddress   String?
  type         String
  club         String?
  memberStatus String    @default("Non-Member")
  notes        String?
  updatedBy    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  bitrixId     String?
  bookings     Booking[]

  @@index([name])
  @@index([mobileNumber])
  @@map("customers")
}

model CustomerMemberStatus {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  @@map("customer_member_statuses")
}

model SourceOfInformation {
  id        String    @id @default(uuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  bookings  Booking[]

  @@map("source_of_informations")
}

model EducationLevel {
  id        String   @id @default(uuid())
  name      String   @unique
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@map("education_levels")
}

model Booking {
  id                       String                     @id @default(uuid())
  bookingDate              DateTime
  bookingStatus            BookingStatus              @default(Pending)
  paymentStatus            String                     @default("")
  weddingSession           WeddingSession?
  weddingType              WeddingType?
  poNumber                 String?
  rejectionNotes           String?
  signingLocation          String?
  signatures               Json?
  salesId                  String
  managerId                String?
  customerId               String
  venueId                  String
  packageId                String
  packageVariantId         String?
  paymentMethodId          String?
  sourceOfInformationId    String?
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt
  lostReason               String?
  commentReads             BookingCommentRead[]
  bookingComments          BookingComment[]
  bookingDocuments         BookingDocument[]
  bookingRefunds           BookingPaymentSettlement[] @relation("SourceSettlements")
  targetSettlements        BookingPaymentSettlement[] @relation("TargetSettlements")
  customer                 Customer                   @relation(fields: [customerId], references: [id])
  manager                  Profile?                   @relation("BookingManager", fields: [managerId], references: [id])
  package                  Package                    @relation(fields: [packageId], references: [id])
  paymentMethod            PaymentMethod?             @relation(fields: [paymentMethodId], references: [id])
  sales                    Profile                    @relation("BookingSales", fields: [salesId], references: [id])
  sourceOfInformation      SourceOfInformation?       @relation(fields: [sourceOfInformationId], references: [id])
  venue                    Venue                      @relation(fields: [venueId], references: [id])
  clientAgreement          ClientAgreement?
  snapBonuses              SnapBonus[]
  snapCustomer             SnapCustomer?
  snapPackageInternalItems SnapPackageInternalItem[]
  snapPackageVariant       SnapPackageVariant?
  snapPackageVendorItems   SnapPackageVendorItem[]
  snapPackage              SnapPackage?
  snapVendorItems          SnapVendorItem[]
  snapVenue                SnapVenue?
  termOfPayments           TermOfPayment[]

  @@index([salesId])
  @@index([managerId])
  @@index([customerId])
  @@index([venueId])
  @@index([packageId])
  @@index([bookingStatus])
  @@index([bookingDate])
  @@map("bookings")
}

model SnapCustomer {
  id           String   @id @default(uuid())
  bookingId    String   @unique
  customerId   String
  name         String
  email        String
  mobileNumber String
  nikNumber    String?
  ktpAddress   String?
  createdAt    DateTime @default(now())
  booking      Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("snap_customers")
}

model SnapVenue {
  id          String   @id @default(uuid())
  bookingId   String   @unique
  venueId     String
  venueName   String
  address     String?
  description String?
  brandName   String?
  brandCode   String?
  createdAt   DateTime @default(now())
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("snap_venues")
}

model SnapPackage {
  id          String   @id @default(uuid())
  bookingId   String   @unique
  packageId   String
  packageName String
  notes       String?
  createdAt   DateTime @default(now())
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("snap_packages")
}

model SnapPackageVariant {
  id          String   @id @default(uuid())
  bookingId   String   @unique
  variantId   String
  variantName String
  pax         Int
  price       BigInt
  createdAt   DateTime @default(now())
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("snap_package_variants")
}

model SnapPackageInternalItem {
  id              String   @id @default(uuid())
  bookingId       String
  itemName        String
  itemDescription String   @default("")
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  booking         Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("snap_package_internal_items")
}

model SnapPackageVendorItem {
  id           String   @id @default(uuid())
  bookingId    String
  categoryName String
  itemText     String
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  booking      Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("snap_package_vendor_items")
}

model SnapBonus {
  id               String       @id @default(uuid())
  bookingId        String
  vendorId         String
  vendorCategoryId String
  vendorName       String
  description      String?
  qty              Int          @default(1)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  nominal          BigInt       @default(0)
  orderStatusId    String?
  booking          Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  orderStatus      OrderStatus? @relation(fields: [orderStatusId], references: [id])

  @@index([bookingId])
  @@index([orderStatusId])
  @@map("snap_bonuses")
}

model SnapVendorItem {
  id                 String                     @id @default(uuid())
  bookingId          String
  vendorCategoryId   String
  vendorCategoryName String
  vendorId           String
  vendorName         String
  itemName           String
  itemPrice          BigInt                     @default(0)
  qty                Int                        @default(1)
  unit               String?
  totalPrice         BigInt                     @default(0)
  isAddons           Boolean                    @default(false)
  paketData          Json?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  description        String?
  orderStatusId      String?
  settlements        BookingPaymentSettlement[]
  booking            Booking                    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  orderStatus        OrderStatus?               @relation(fields: [orderStatusId], references: [id])

  @@index([bookingId])
  @@index([orderStatusId])
  @@map("snap_vendor_items")
}

model TermOfPayment {
  id              String              @id @default(uuid())
  bookingId       String
  name            String
  amount          BigInt
  dueDate         DateTime
  paymentStatus   TermOfPaymentStatus @default(unpaid)
  paymentEvidence String?
  invoiceNumber   String?
  notes           String?
  sortOrder       Int                 @default(0)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  booking         Booking             @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("term_of_payments")
}

model BookingDocument {
  id          String   @id @default(uuid())
  bookingId   String
  name        String
  description String?
  filePath    String
  fileName    String
  fileSize    Int      @default(0)
  fileType    String?
  uploadedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  uploader    Profile? @relation(fields: [uploadedBy], references: [id])

  @@index([bookingId])
  @@map("booking_documents")
}

model BookingComment {
  id          String           @id @default(uuid())
  bookingId   String
  authorId    String
  content     String
  mentions    String[]
  replyToId   String?
  edited      Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  attachments Json             @default("[]")
  author      Profile          @relation(fields: [authorId], references: [id])
  booking     Booking          @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  replyTo     BookingComment?  @relation("CommentReplies", fields: [replyToId], references: [id])
  replies     BookingComment[] @relation("CommentReplies")

  @@index([bookingId, createdAt])
  @@index([authorId])
  @@map("booking_comments")
}

model BookingCommentRead {
  profileId  String
  bookingId  String
  lastReadAt DateTime @default(now()) @updatedAt
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  profile    Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@id([profileId, bookingId])
  @@map("booking_comment_reads")
}

model BookingPaymentSettlement {
  id               String           @id @default(uuid())
  bookingId        String
  snapVendorItemId String
  type             SettlementType
  amount           BigInt
  paymentMethodId  String?
  targetBookingId  String?
  status           SettlementStatus @default(pending)
  notes            String?
  settledAt        DateTime?
  createdBy        String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  booking          Booking          @relation("SourceSettlements", fields: [bookingId], references: [id], onDelete: Cascade)
  creator          Profile?         @relation(fields: [createdBy], references: [id])
  paymentMethod    PaymentMethod?   @relation(fields: [paymentMethodId], references: [id])
  snapVendorItem   SnapVendorItem   @relation(fields: [snapVendorItemId], references: [id], onDelete: Cascade)
  targetBooking    Booking?         @relation("TargetSettlements", fields: [targetBookingId], references: [id])

  @@index([bookingId])
  @@index([snapVendorItemId])
  @@index([status])
  @@map("booking_payment_settlements")
}

model OrderStatus {
  id              String           @id @default(uuid())
  name            String           @unique
  sortOrder       Int              @default(0)
  createdAt       DateTime         @default(now())
  snapBonuses     SnapBonus[]
  snapVendorItems SnapVendorItem[]

  @@map("order_statuses")
}

model ClientAgreement {
  id         String          @id @default(uuid())
  bookingId  String          @unique
  token      String          @unique
  accessCode String
  status     AgreementStatus @default(Pending)
  sentAt     DateTime?
  viewedAt   DateTime?
  signedAt   DateTime?
  expiresAt  DateTime
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  booking    Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("client_agreements")
}

model Notification {
  id         String   @id @default(uuid())
  userId     String
  title      String
  message    String
  type       String
  entityType String?
  entityId   String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  profile    Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

model approval_flow_steps {
  id             String         @id
  flowId         String
  sortOrder      Int
  approverType   String
  approverRoleId String?
  approverUserId String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime
  roles          Role?          @relation(fields: [approverRoleId], references: [id])
  profiles       Profile?       @relation(fields: [approverUserId], references: [id])
  approval_flows approval_flows @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@index([flowId])
}

model approval_flows {
  id                  String                @id
  module              String                @unique
  name                String
  active              Boolean               @default(true)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime
  approval_flow_steps approval_flow_steps[]
}

model approval_record_steps {
  id                                                      String           @id
  recordId                                                String
  stepOrder                                               Int
  approverType                                            String
  approverRoleId                                          String?
  approverUserId                                          String?
  status                                                  String           @default("pending")
  decidedById                                             String?
  decidedAt                                               DateTime?
  notes                                                   String?
  createdAt                                               DateTime         @default(now())
  signature                                               String?
  roles                                                   Role?            @relation(fields: [approverRoleId], references: [id])
  profiles_approval_record_steps_approverUserIdToprofiles Profile?         @relation("approval_record_steps_approverUserIdToprofiles", fields: [approverUserId], references: [id])
  profiles_approval_record_steps_decidedByIdToprofiles    Profile?         @relation("approval_record_steps_decidedByIdToprofiles", fields: [decidedById], references: [id])
  approval_records                                        approval_records @relation(fields: [recordId], references: [id], onDelete: Cascade)

  @@index([recordId])
}

model approval_records {
  id                    String                  @id
  module                String
  entityId              String
  status                String                  @default("pending")
  createdById           String
  createdAt             DateTime                @default(now())
  updatedAt             DateTime
  signature             String?
  approval_record_steps approval_record_steps[]
  profiles              Profile                 @relation(fields: [createdById], references: [id])

  @@unique([module, entityId])
  @@index([createdById])
  @@index([module, entityId])
}

model package_variant_category_prices {
  id               String         @id
  packageVariantId String
  categoryName     String
  basePrice        Int            @default(0)
  sortOrder        Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime
  package_variants PackageVariant @relation(fields: [packageVariantId], references: [id], onDelete: Cascade)

  @@index([packageVariantId])
}

