generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth Models ─────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  profile       Profile?
  sessions      Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Profile & RBAC ──────────────────────────────────────────────────────────

model Profile {
  id             String  @id @default(uuid())
  userId         String  @unique
  email          String  @unique
  employeeNumber Int     @unique @default(autoincrement())
  fullName       String?
  nickName       String?
  gender         Gender?
  phoneNumber    String?
  avatarUrl      String?

  // Personal data
  nik              String?
  kkNumber         String?
  placeOfBirth     String?
  dateOfBirth      DateTime?
  ktpAddress       String?
  currentAddress   String?
  city             String?
  motherName       String?
  maritalStatus    String?
  numberOfChildren Int?
  lastEducation    String?

  // Payroll
  bankName          String?
  bankAccountNumber String?
  bankAccountHolder String?

  // Emergency contact
  emergencyContactName  String?
  emergencyContactRel   String?
  emergencyContactPhone String?

  // Access control
  roleId    String?
  dataScope DataScope     @default(own)
  status    ProfileStatus @default(active)

  // Metadata
  invitedBy          String?
  invitedAt          DateTime?
  isEmailVerified    Boolean   @default(false)
  mustChangePassword Boolean   @default(false)
  lastLoginAt        DateTime?
  language           String    @default("id")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  activityLogs            ActivityLog[]
  role                    Role?                      @relation(fields: [roleId], references: [id], onDelete: SetNull)
  user                    User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userVenueAccess         UserVenueAccess[]
  managedVenueAccess      UserVenueAccess[]          @relation("VenueAccessManager")
  dataGroupMemberships    UserGroupMember[]
  ledGroups               UserGroup[]                @relation("GroupLeader")
  bookingsAsSales         Booking[]                  @relation("BookingSales")
  bookingsAsManager       Booking[]                  @relation("BookingManager")
  uploadedDocuments       BookingDocument[]
  createdSettlements      BookingPaymentSettlement[]
  notifications           Notification[]
  bookingComments         BookingComment[]
  bookingCommentReads     BookingCommentRead[]
  approvalSteps           ApprovalFlowStep[]
  approvalRecordsCreated  ApprovalRecord[]           @relation("ApprovalRecordCreator")
  approvalStepApprovals   ApprovalRecordStep[]       @relation("ApprovalRecordStepApprover")
  approvalStepDecisions   ApprovalRecordStep[]       @relation("ApprovalRecordStepDecider")

  @@index([roleId])
  @@index([dataScope])
  @@map("profiles")
}

model Role {
  id                  String               @id @default(uuid())
  name                String               @unique
  description         String?
  sortOrder           Int                  @default(0)
  createdAt           DateTime             @default(now())
  profiles            Profile[]
  rolePermissions     RolePermission[]
  approvalSteps       ApprovalFlowStep[]
  approvalRecordSteps ApprovalRecordStep[] @relation("ApprovalRecordStepRole")

  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid())
  module          String
  action          String
  description     String?
  moduleSortOrder Int              @default(0)
  createdAt       DateTime         @default(now())
  rolePermissions RolePermission[]

  @@unique([module, action])
  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

// ─── Auth Tokens ─────────────────────────────────────────────────────────────

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  profile   Profile   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String    @id @default(uuid())
  profileId String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  profile   Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@map("email_verification_tokens")
}

// ─── Data Groups (untuk scope = 'group') ─────────────────────────────────────

model UserGroup {
  id          String            @id @default(uuid())
  name        String
  description String?
  leaderId    String?
  sortOrder   Int               @default(0)
  createdBy   String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  leader      Profile?          @relation("GroupLeader", fields: [leaderId], references: [id], onDelete: SetNull)
  members     UserGroupMember[]

  @@index([leaderId])
  @@map("user_groups")
}

model UserGroupMember {
  groupId   String
  userId    String
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  group     UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  profile   Profile   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
  @@index([userId])
  @@map("user_group_members")
}

// ─── Venue (dipakai untuk user invitation — assign venue ke user) ─────────────

model Brand {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  createdAt DateTime @default(now())
  venues    Venue[]

  @@map("brands")
}

model Venue {
  id              String            @id @default(uuid())
  name            String
  description     String?
  address         String?
  capacity        Int?
  imageUrl        String?
  code            String            @default("KODE")
  brandId         String?
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  brand           Brand?            @relation(fields: [brandId], references: [id], onDelete: SetNull)
  userVenueAccess UserVenueAccess[]
  packages        Package[]
  paymentMethods  PaymentMethod[]
  bookings        Booking[]

  @@index([brandId])
  @@map("venues")
}

model UserVenueAccess {
  id        String           @id @default(uuid())
  userId    String
  venueId   String
  managerId String?
  scope     VenueAccessScope @default(individual)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  profile   Profile          @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue     Venue            @relation(fields: [venueId], references: [id], onDelete: Cascade)
  manager   Profile?         @relation("VenueAccessManager", fields: [managerId], references: [id], onDelete: SetNull)

  @@unique([userId, venueId])
  @@index([userId])
  @@index([managerId])
  @@map("user_venue_access")
}

// ─── Audit Logging ───────────────────────────────────────────────────────────

model ActivityLog {
  id          String   @id @default(uuid())
  userId      String?
  action      String
  result      String   @default("success")
  entityType  String
  entityId    String
  changes     Json     @default("{}")
  description String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  profile     Profile? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([userId])
  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([entityType, entityId, createdAt])
  @@map("activity_logs")
}

// ─── Vendors ─────────────────────────────────────────────────────────────────

model VendorCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  vendors     Vendor[]

  @@map("vendor_categories")
}

model Vendor {
  id             String          @id @default(uuid())
  name           String
  categoryId     String
  description    String?
  phone          String?
  address        String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  category       VendorCategory  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  paymentMethods PaymentMethod[]

  @@index([categoryId])
  @@map("vendors")
}

model PaymentMethod {
  id                String                     @id @default(uuid())
  vendorId          String?
  venueId           String?
  bankName          String
  bankAccountNumber String
  bankRecipient     String
  createdAt         DateTime                   @default(now())
  vendor            Vendor?                    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  venue             Venue?                     @relation(fields: [venueId], references: [id], onDelete: Cascade)
  bookings          Booking[]
  settlements       BookingPaymentSettlement[]

  @@index([vendorId])
  @@index([venueId])
  @@map("payment_methods")
}

// ─── Packages ────────────────────────────────────────────────────────────────

model Package {
  id             String           @id @default(uuid())
  packageName    String
  available      Boolean          @default(true)
  approvalStatus String           @default("draft")
  venueId        String?
  notes          String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  venue          Venue?           @relation(fields: [venueId], references: [id], onDelete: SetNull)
  variants       PackageVariant[]
  bookings       Booking[]

  @@index([venueId])
  @@map("packages")
}

model PackageVariant {
  id             String                        @id @default(uuid())
  packageId      String
  variantName    String
  pax            Int
  margin         Float                         @default(0)
  available      Boolean                       @default(true)
  createdAt      DateTime                      @default(now())
  updatedAt      DateTime                      @updatedAt
  package        Package                       @relation(fields: [packageId], references: [id], onDelete: Cascade)
  vendorItems    PackageVendorItem[]
  internalItems  PackageInternalItem[]
  categoryPrices PackageVariantCategoryPrice[]
  bookings       Booking[]

  @@index([packageId])
  @@map("package_variants")
}

model PackageVariantCategoryPrice {
  id               String         @id @default(uuid())
  packageVariantId String
  categoryName     String
  basePrice        Int            @default(0)
  sortOrder        Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  packageVariant   PackageVariant @relation(fields: [packageVariantId], references: [id], onDelete: Cascade)

  @@index([packageVariantId])
  @@map("package_variant_category_prices")
}

model PackageVendorItem {
  id               String         @id @default(uuid())
  packageVariantId String
  categoryName     String
  itemText         String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  packageVariant   PackageVariant @relation(fields: [packageVariantId], references: [id], onDelete: Cascade)

  @@index([packageVariantId])
  @@map("package_vendor_items")
}

model PackageInternalItem {
  id               String         @id @default(uuid())
  packageVariantId String
  itemName         String
  itemDescription  String         @default("")
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  packageVariant   PackageVariant @relation(fields: [packageVariantId], references: [id], onDelete: Cascade)

  @@index([packageVariantId])
  @@map("package_internal_items")
}

// ─── Customers ───────────────────────────────────────────────────────────────

model Customer {
  id           String    @id @default(uuid())
  name         String
  mobileNumber Json      @default("[]")
  email        String
  nikNumber    String?
  ktpAddress   String?
  type         String
  club         String?
  memberStatus String    @default("Non-Member")
  notes        String?
  bitrixId     String?
  sourceOfInformationId String?
  updatedBy             String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  bookings              Booking[]
  sourceOfInformation   SourceOfInformation? @relation(fields: [sourceOfInformationId], references: [id], onDelete: SetNull)

  @@index([name])
  @@map("customers")
}

// ─── Customer Member Status ───────────────────────────────────────────────────

model CustomerMemberStatus {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  @@map("customer_member_statuses")
}

// ─── Source of Information ────────────────────────────────────────────────────

model SourceOfInformation {
  id        String     @id @default(uuid())
  name      String     @unique
  createdAt DateTime   @default(now())
  bookings  Booking[]
  customers Customer[]

  @@map("source_of_informations")
}

model EducationLevel {
  id        String   @id @default(uuid())
  name      String   @unique
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@map("education_levels")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum ProfileStatus {
  active
  inactive
  suspended
}

enum Gender {
  MALE
  FEMALE
}

enum DataScope {
  own
  group
  all
}

enum VenueAccessScope {
  general
  individual
}

// ─── Bookings ────────────────────────────────────────────────────────────────

model Booking {
  id                    String          @id @default(uuid())
  bookingDate           DateTime
  bookingStatus         BookingStatus   @default(Pending)
  paymentStatus         String          @default("")
  weddingSession        WeddingSession?
  weddingType           WeddingType?
  poNumber              String?
  rejectionNotes        String?
  lostReason            String?
  signingLocation       String?
  signatures            Json?
  salesId               String
  managerId             String?
  customerId            String
  venueId               String
  packageId             String
  packageVariantId      String?
  paymentMethodId       String?
  sourceOfInformationId String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  sales               Profile              @relation("BookingSales", fields: [salesId], references: [id], onDelete: Restrict)
  manager             Profile?             @relation("BookingManager", fields: [managerId], references: [id])
  customer            Customer             @relation(fields: [customerId], references: [id], onDelete: Restrict)
  venue               Venue                @relation(fields: [venueId], references: [id], onDelete: Restrict)
  package             Package              @relation(fields: [packageId], references: [id], onDelete: Restrict)
  packageVariant      PackageVariant?      @relation(fields: [packageVariantId], references: [id], onDelete: SetNull)
  paymentMethod       PaymentMethod?       @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  sourceOfInformation SourceOfInformation? @relation(fields: [sourceOfInformationId], references: [id], onDelete: SetNull)

  // Snapshot relations (1:1)
  snapCustomer       SnapCustomer?
  snapVenue          SnapVenue?
  snapPackage        SnapPackage?
  snapPackageVariant SnapPackageVariant?

  // Snapshot relations (1:many)
  snapPackageInternalItems SnapPackageInternalItem[]
  snapPackageVendorItems   SnapPackageVendorItem[]
  snapBonuses              SnapBonus[]
  snapVendorItems          SnapVendorItem[]

  // Live relations
  termOfPayments    TermOfPayment[]
  bookingDocuments  BookingDocument[]
  bookingRefunds    BookingPaymentSettlement[] @relation("SourceSettlements")
  targetSettlements BookingPaymentSettlement[] @relation("TargetSettlements")
  clientAgreement   ClientAgreement?
  bookingComments   BookingComment[]
  commentReads      BookingCommentRead[]

  @@index([salesId])
  @@index([managerId])
  @@index([customerId])
  @@index([venueId])
  @@index([packageId])
  @@index([packageVariantId])
  @@index([paymentMethodId])
  @@index([sourceOfInformationId])
  @@index([bookingStatus])
  @@index([bookingDate])
  @@map("bookings")
}

// ─── Snapshot Tables ─────────────────────────────────────────────────────────

model SnapCustomer {
  id           String   @id @default(uuid())
  bookingId    String   @unique
  customerId   String
  name         String
  email        String
  mobileNumber String
  nikNumber    String?
  ktpAddress   String?
  createdAt    DateTime @default(now())
  booking      Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("snap_customers")
}

model SnapVenue {
  id          String   @id @default(uuid())
  bookingId   String   @unique
  venueId     String
  venueName   String
  address     String?
  description String?
  brandName   String?
  brandCode   String?
  createdAt   DateTime @default(now())
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("snap_venues")
}

model SnapPackage {
  id          String   @id @default(uuid())
  bookingId   String   @unique
  packageId   String
  packageName String
  notes       String?
  createdAt   DateTime @default(now())
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("snap_packages")
}

model SnapPackageVariant {
  id          String   @id @default(uuid())
  bookingId   String   @unique
  variantId   String
  variantName String
  pax         Int
  price       Int
  createdAt   DateTime @default(now())
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("snap_package_variants")
}

model SnapPackageInternalItem {
  id              String   @id @default(uuid())
  bookingId       String
  itemName        String
  itemDescription String   @default("")
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  booking         Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("snap_package_internal_items")
}

model SnapPackageVendorItem {
  id           String   @id @default(uuid())
  bookingId    String
  categoryName String
  itemText     String
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  booking      Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("snap_package_vendor_items")
}

model SnapBonus {
  id               String       @id @default(uuid())
  bookingId        String
  vendorId         String
  vendorCategoryId String
  vendorName       String
  description      String?
  qty              Int          @default(1)
  nominal          Int          @default(0)
  orderStatusId    String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  booking          Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  orderStatus      OrderStatus? @relation(fields: [orderStatusId], references: [id], onDelete: SetNull)

  @@index([bookingId])
  @@index([orderStatusId])
  @@map("snap_bonuses")
}

model SnapVendorItem {
  id                 String                     @id @default(uuid())
  bookingId          String
  vendorCategoryId   String
  vendorCategoryName String
  vendorId           String
  vendorName         String
  itemName           String
  itemPrice          Int                        @default(0)
  qty                Int                        @default(1)
  unit               String?
  totalPrice         Int                        @default(0)
  isAddons           Boolean                    @default(false)
  paketData          Json?
  description        String?
  orderStatusId      String?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  booking            Booking                    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  orderStatus        OrderStatus?               @relation(fields: [orderStatusId], references: [id], onDelete: SetNull)
  settlements        BookingPaymentSettlement[]

  @@index([bookingId])
  @@index([orderStatusId])
  @@map("snap_vendor_items")
}

// ─── Booking Live Tables ─────────────────────────────────────────────────────

model TermOfPayment {
  id              String              @id @default(uuid())
  bookingId       String
  name            String
  amount          Int
  dueDate         DateTime
  paymentStatus   TermOfPaymentStatus @default(unpaid)
  paymentEvidence String?
  invoiceNumber   String?
  notes           String?
  sortOrder       Int                 @default(0)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  booking         Booking             @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@unique([invoiceNumber])
  @@index([bookingId])
  @@map("term_of_payments")
}

model BookingDocument {
  id          String   @id @default(uuid())
  bookingId   String
  name        String
  description String?
  filePath    String
  fileName    String
  fileSize    Int      @default(0)
  fileType    String?
  uploadedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  uploader    Profile? @relation(fields: [uploadedBy], references: [id], onDelete: SetNull)

  @@index([bookingId])
  @@index([uploadedBy])
  @@map("booking_documents")
}

model BookingComment {
  id          String   @id @default(uuid())
  bookingId   String
  authorId    String
  content     String
  mentions    String[]
  replyToId   String?
  edited      Boolean  @default(false)
  attachments Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  booking Booking          @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  author  Profile          @relation(fields: [authorId], references: [id], onDelete: Restrict)
  replyTo BookingComment?  @relation("CommentReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies BookingComment[] @relation("CommentReplies")

  @@index([bookingId, createdAt])
  @@index([authorId])
  @@index([replyToId])
  @@map("booking_comments")
}

model BookingCommentRead {
  profileId  String
  bookingId  String
  lastReadAt DateTime @default(now()) @updatedAt

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@id([profileId, bookingId])
  @@map("booking_comment_reads")
}

model BookingPaymentSettlement {
  id               String           @id @default(uuid())
  bookingId        String
  snapVendorItemId String
  type             SettlementType
  amount           Int
  paymentMethodId  String?
  targetBookingId  String?
  status           SettlementStatus @default(pending)
  notes            String?
  settledAt        DateTime?
  createdBy        String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  booking        Booking        @relation("SourceSettlements", fields: [bookingId], references: [id], onDelete: Cascade)
  targetBooking  Booking?       @relation("TargetSettlements", fields: [targetBookingId], references: [id], onDelete: SetNull)
  snapVendorItem SnapVendorItem @relation(fields: [snapVendorItemId], references: [id], onDelete: Cascade)
  paymentMethod  PaymentMethod? @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)
  creator        Profile?       @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([bookingId])
  @@index([snapVendorItemId])
  @@index([paymentMethodId])
  @@index([targetBookingId])
  @@index([createdBy])
  @@index([status])
  @@map("booking_payment_settlements")
}

// ─── Booking Enums ───────────────────────────────────────────────────────────

enum BookingStatus {
  Pending
  Uploaded
  Confirmed
  Rejected
  Canceled
  Lost
}

enum WeddingSession {
  morning
  afternoon
  evening
  fullday
}

enum WeddingType {
  wedding
  engagement
  akad
  resepsi
  other
}

enum TermOfPaymentStatus {
  unpaid
  paid
  partial
}

enum SettlementType {
  refund
  allocation
}

enum SettlementStatus {
  pending
  completed
  cancelled
}

enum AgreementStatus {
  Pending
  Sent
  Viewed
  Signed
}

// ─── Order Status ─────────────────────────────────────────────────────────────

model OrderStatus {
  id              String           @id @default(uuid())
  name            String           @unique
  sortOrder       Int              @default(0)
  createdAt       DateTime         @default(now())
  snapVendorItems SnapVendorItem[]
  snapBonuses     SnapBonus[]

  @@map("order_statuses")
}

// ─── Client Agreement ─────────────────────────────────────────────────────────

model ClientAgreement {
  id         String          @id @default(uuid())
  bookingId  String          @unique
  token      String          @unique
  accessCode String
  status     AgreementStatus @default(Pending)
  sentAt     DateTime?
  viewedAt   DateTime?
  signedAt   DateTime?
  expiresAt  DateTime
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("client_agreements")
}

// ─── Approval Flow ────────────────────────────────────────────────────────────

model ApprovalFlow {
  id        String             @id @default(uuid())
  module    String             @unique
  name      String
  active    Boolean            @default(true)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  steps     ApprovalFlowStep[]

  @@map("approval_flows")
}

model ApprovalFlowStep {
  id             String       @id @default(uuid())
  flowId         String
  sortOrder      Int
  approverType   String // "role" | "user"
  approverRoleId String?
  approverUserId String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  flow           ApprovalFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)
  approverRole   Role?        @relation(fields: [approverRoleId], references: [id], onDelete: SetNull)
  approverUser   Profile?     @relation(fields: [approverUserId], references: [id], onDelete: SetNull)

  @@index([flowId])
  @@index([approverRoleId])
  @@index([approverUserId])
  @@map("approval_flow_steps")
}

model ApprovalRecord {
  id          String               @id @default(uuid())
  module      String
  entityId    String
  status      String               @default("pending")
  signature   String?
  createdById String
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  createdBy   Profile              @relation("ApprovalRecordCreator", fields: [createdById], references: [id], onDelete: Restrict)
  steps       ApprovalRecordStep[]

  @@unique([module, entityId])
  @@index([createdById])
  @@map("approval_records")
}

model ApprovalRecordStep {
  id             String         @id @default(uuid())
  recordId       String
  stepOrder      Int
  approverType   String
  approverRoleId String?
  approverUserId String?
  status         String         @default("pending")
  signature      String?
  decidedById    String?
  decidedAt      DateTime?
  notes          String?
  createdAt      DateTime       @default(now())
  record         ApprovalRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  approverRole   Role?          @relation("ApprovalRecordStepRole", fields: [approverRoleId], references: [id], onDelete: SetNull)
  approverUser   Profile?       @relation("ApprovalRecordStepApprover", fields: [approverUserId], references: [id], onDelete: SetNull)
  decidedBy      Profile?       @relation("ApprovalRecordStepDecider", fields: [decidedById], references: [id], onDelete: SetNull)

  @@index([recordId])
  @@index([approverRoleId])
  @@index([approverUserId])
  @@index([decidedById])
  @@map("approval_record_steps")
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id         String   @id @default(uuid())
  userId     String
  title      String
  message    String
  type       String
  entityType String?
  entityId   String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  profile    Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

model Counter {
  id    String @id // e.g. "invoice-2026"
  value Int    @default(0)

  @@map("counters")
}
